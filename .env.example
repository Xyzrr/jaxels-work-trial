# Optional dotenv file for local/pod launches.
#
# Keep this file limited to secrets and observability defaults. Model identity,
# dataset choice, sequence length, precision, optimizer settings, vLLM sizing,
# and other ML experiment decisions belong in argparse preset files under
# configs/ so each run has one reviewable source of truth.

# Enables Weights & Biases logging when a real key is supplied. W&B records
# training curves, loss, throughput, and run metadata; it does not choose the
# model, data, or hyperparameters.
WANDB_API_KEY=

# Default W&B destination for prototype runs. The training launcher can record
# these in run metadata, while the API key above remains secret and is not
# written into reproducibility artifacts.
WANDB_ENTITY=jaxels
WANDB_PROJECT=jaxels-midtraining

# Human-readable W&B label only. Treat this as observability naming, not an
# experiment definition; canonical experiment names and ML settings should live
# in config presets and run specs.
WANDB_RUN_NAME=qwen-agentic-smoke

# Hugging Face authentication for downloading gated/private model assets such
# as tokenizer files, model configs, and safetensors checkpoints. The selected
# model revision is still controlled by presets/CLI, not by this token.
HF_TOKEN=
